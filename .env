# AI-Powered Real Estate System Environment Configuration

# ==========================================
# CORE SYSTEM CONFIGURATION
# ==========================================

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true
FLASK_SECRET_KEY=your-secret-key-here-change-in-production

# ==========================================
# BASEROW DATABASE CONFIGURATION
# ==========================================

# Baserow API Configuration
BASEROW_API_URL=https://dayta.intelligentb2b.com/api
BASEROW_TOKEN=your_baserow_token_here

# Baserow Table IDs (to be filled after running setup_baserow_tables.py)
BASEROW_PROPERTIES_TABLE_ID=
BASEROW_USERS_TABLE_ID=
BASEROW_LEADS_TABLE_ID=
BASEROW_INTERACTIONS_TABLE_ID=
BASEROW_DEALS_TABLE_ID=
BASEROW_MARKET_DATA_TABLE_ID=
BASEROW_EMAIL_CAMPAIGNS_TABLE_ID=
BASEROW_ANALYTICS_TABLE_ID=

# Baserow Application ID (find in your Baserow dashboard URL)
BASEROW_APPLICATION_ID=your_application_id_here

# ==========================================
# OPEN WEBUI CONFIGURATION
# ==========================================

# Open WebUI Settings
OPEN_WEBUI_URL=https://ai.intelligentb2b.com
OPEN_WEBUI_API_KEY=your_open_webui_api_key_here

# ==========================================
# EXTERNAL API INTEGRATIONS
# ==========================================

# Real Estate Portal APIs
IMMOBILIARE_API_KEY=your_immobiliare_api_key
IDEALISTA_API_KEY=your_idealista_api_key
QUOTAZIONI_START_API_KEY=your_quotazioni_start_api_key

# AI Services
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ==========================================
# EMAIL CONFIGURATION
# ==========================================

# SMTP Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Email Templates
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# ==========================================
# N8N WORKFLOW CONFIGURATION
# ==========================================

# n8n Instance Configuration
N8N_URL=http://localhost:5678
N8N_API_KEY=your_n8n_api_key

# ==========================================
# SECURITY CONFIGURATION
# ==========================================

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ACCESS_TOKEN_EXPIRES=3600

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "https://yourdomain.com"]

# ==========================================
# LOGGING CONFIGURATION
# ==========================================

# Log Levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ==========================================
# CACHE CONFIGURATION
# ==========================================

# Redis Configuration (optional, for caching)
REDIS_URL=redis://localhost:6379
CACHE_TYPE=simple

# ==========================================
# MONITORING CONFIGURATION
# ==========================================

# Health Check Configuration
HEALTH_CHECK_INTERVAL=300
MONITORING_ENABLED=true

# ==========================================
# DEVELOPMENT CONFIGURATION
# ==========================================

# Development Database (SQLite for local development)
DEV_DATABASE_URL=sqlite:///dev.db

# Testing Configuration
TESTING=false
TEST_DATABASE_URL=sqlite:///test.db
